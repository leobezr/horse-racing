{
  "name": "horse-racing",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test:storybook:snapshots": "playwright test --config playwright.storybook.config.ts",
    "test:storybook:snapshots:update": "playwright test --config playwright.storybook.config.ts --update-snapshots",
    "test:storybook:snapshots:update:local": "node ./scripts/storybook-snapshots-local.mjs",
    "test:storybook:snapshots:deployed-vs-local": "node ./scripts/storybook-snapshots-deployed-vs-local.mjs",
    "test": "jest --watch",
    "test:run": "jest --runInBand",
    "context:get": "node ./scripts/copilot-context.mjs get",
    "context:set": "node ./scripts/copilot-context.mjs set",
    "context:set:developer": "node ./scripts/copilot-context.mjs set developer",
    "context:set:orchestrator": "node ./scripts/copilot-context.mjs set orchestrator",
    "lint": "eslint \"src/**/*.{ts,vue}\"",
    "lint:fix": "eslint \"src/**/*.{ts,vue}\" --fix",
    "guardrails": "node ./scripts/guardrails.mjs",
    "typecheck": "vue-tsc --noEmit",
    "verify": "yarn lint && yarn typecheck && yarn test:run && yarn guardrails"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/leobezr/horse-racing.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "bugs": {
    "url": "https://github.com/leobezr/horse-racing/issues"
  },
  "homepage": "https://github.com/leobezr/horse-racing#readme",
  "dependencies": {
    "pinia": "^3.0.4",
    "seedrandom": "^3.0.5",
    "vue": "^3.5.32",
    "vue-router": "^5.0.4",
    "vuetify": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-interactions": "^8.6.14",
    "@storybook/addon-links": "8.6.14",
    "@storybook/vue3-vite": "8.6.14",
    "@types/jest": "^30.0.0",
    "@types/seedrandom": "^3.0.8",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "@vitejs/plugin-vue": "^6.0.6",
    "eslint": "^10.2.0",
    "eslint-plugin-vue": "^10.8.0",
    "globals": "^17.5.0",
    "jest": "^30.3.0",
    "http-server": "^14.1.1",
    "@playwright/test": "^1.55.0",
    "sass": "^1.99.0",
    "storybook": "8.6.14",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  }
}
